</div>

<script>
function $(id){return document.getElementById(id);}

function fmt(n){
  n = Math.round(n * 100) / 100;
  return '¥' + n.toLocaleString('zh-CN', {maximumFractionDigits:2});
}

function monthsBetween(d1, d2){
  if(!d1 || !d2) return 0;
  let months = (d2.getFullYear()-d1.getFullYear())*12 + (d2.getMonth()-d1.getMonth());
  if(d2.getDate() < d1.getDate()) months -= 1;
  let tmp = new Date(d1);
  tmp.setMonth(tmp.getMonth()+months);
  let extraDays = Math.round((d2 - tmp) / (1000*60*60*24));
  return {months: Math.max(months,0), extraDays: Math.max(extraDays,0)};
}

function calc(){
  const hireVal = $('hireDate').value;
  const leaveVal = $('leaveDate').value;
  const avgWage = parseFloat($('avgWage').value) || 0;
  const localWage = parseFloat($('localWage').value) || 0;
  const mode = document.querySelector('input[name=mode]:checked').value;
  const noNotice = $('noNotice').checked;
  const leaveDays = parseFloat($('leaveDays').value) || 0;
  const leaveType = $('leaveType').value;
  const otWeekday = parseFloat($('otWeekday').value) || 0;
  const otWeekend = parseFloat($('otWeekend').value) || 0;
  const otHoliday = parseFloat($('otHoliday').value) || 0;
  const noContract = $('noContract').value;
  const unsignedMonths = parseFloat($('unsignedMonths').value) || 0;
  const owedWage = parseFloat($('owedWage').value) || 0;
  const owedCommission = parseFloat($('owedCommission').value) || 0;
  const companyListed = $('companyListed').value;
  const optionStatus = $('optionStatus').value;
  const optionShares = parseFloat($('optionShares').value) || 0;
  const strikePrice = parseFloat($('strikePrice').value) || 0;
  const fairValue = parseFloat($('fairValue').value) || 0;
  const buybackPrice = parseFloat($('buybackPrice').value) || 0;

  $('unsignedMonthsWrap').style.display = (noContract === 'unsigned') ? 'block' : 'none';
  $('noContractWarn').style.display = (noContract === 'unsigned') ? 'block' : 'none';

  $('benefitLeaveWarn').style.display = (leaveType === 'benefit') ? 'block' : 'none';
  const isNoticeEligible = (mode === 'employer40' || mode === 'pip40');
  $('noticeWrap').style.opacity = isNoticeEligible ? '1' : '0.45';
  $('pipPanel').style.display = (mode === 'pip40') ? 'block' : 'none';
  $('probationPanel').style.display = (mode === 'probation_valid' || mode === 'probation_illegal') ? 'block' : 'none';

  let yearsForN = 0;
  let yearsLabel = '—';
  if(hireVal && leaveVal){
    const d1 = new Date(hireVal), d2 = new Date(leaveVal);
    if(d2 > d1){
      const {months, extraDays} = monthsBetween(d1, d2);
      const fullYears = Math.floor(months/12);
      let remMonths = months % 12;
      if(remMonths >= 6){
        yearsForN = fullYears + 1;
      } else if(remMonths >= 1 || extraDays > 0){
        yearsForN = fullYears + 0.5;
      } else {
        yearsForN = fullYears;
      }
      const totalYearsDisplay = (months/12).toFixed(1);
      yearsLabel = totalYearsDisplay + ' 年（计算补偿按 ' + yearsForN + ' 个月工资标准）';
    }
  }

  let wageBase = avgWage;
  let capped = false;
  let cappedYears = yearsForN;
  if(localWage > 0 && avgWage > localWage * 3){
    wageBase = localWage * 3;
    capped = true;
    if(cappedYears > 12) cappedYears = 12;
  }

  let compRaw = cappedYears * wageBase;
  let compMultiplier = 1;
  let compLabelText = '经济补偿 N';
  let compNoteText = '';
  let zeroComp = false;

  if(mode === 'illegal' || mode === 'probation_illegal'){
    compMultiplier = 2;
    compLabelText = '赔偿金 2N';
  } else if(mode === 'employee_resign' || mode === 'employee_fault' || mode === 'probation_valid'){
    zeroComp = true;
    compMultiplier = 0;
    compLabelText = '经济补偿';
    compNoteText = '按此解除方式，法律上通常无需支付';
  }

  if(capped){
    compNoteText += (compNoteText? '；':'') + '已按社平工资3倍封顶，年限最高12年';
  }

  let comp = compRaw * compMultiplier;

  let notice = 0;
  if((mode === 'employer40' || mode === 'pip40') && noNotice){
    notice = wageBase;
  }

  let dailyWage = avgWage / 21.75;
  let leaveComp = 0;
  if(leaveDays > 0){
    leaveComp = dailyWage * 2 * leaveDays;
  }

  let hourlyWage = avgWage / 21.75 / 8;
  let otComp = hourlyWage*1.5*otWeekday + hourlyWage*2*otWeekend + hourlyWage*3*otHoliday;

  let contractComp = 0;
  if(noContract === 'unsigned' && unsignedMonths > 0){
    const payableMonths = Math.max(0, Math.min(unsignedMonths - 1, 11));
    contractComp = payableMonths * avgWage;
  }

  let owedTotal = owedWage + owedCommission;

  let optionValue = 0;
  let optionNote = '';

  if(optionStatus === 'unvested'){
    optionValue = 0;
    optionNote = '<strong>尚未归属的期权/股权，绝大多数股权激励协议约定离职即作废（forfeiture）</strong>，法院通常尊重协议约定，参考估值按0处理。仅在协议存在"离职加速归属"等特别约定，或单位存在恶意规避归属条件的证据时，才可能例外争取部分归属。';
  } else {
    let perShareValue = 0;
    if(buybackPrice > 0){
      perShareValue = buybackPrice;
      optionNote = '已按你填写的<strong>协议约定回购价格</strong>估算——未上市公司常见按原授予价/行权价甚至更低的固定价格回购，与公允价值可能相差很大，请以协议原文为准。';
    } else if(fairValue > 0){
      if(optionStatus === 'vested_unexercised'){
        perShareValue = Math.max(0, fairValue - strikePrice);
        optionNote = '按"公允价值−行权价"的内在价值估算（假设可顺利行权并变现）。未上市公司的"公允价值"本身即存在争议，法院可能采纳最近一轮融资价格、评估报告或直接不予支持，分歧很大。';
      } else {
        perShareValue = fairValue;
        optionNote = '按公允价值估算你已持有股票/RSU的账面价值。已上市公司通常以离职当日或约定基准日收盘价估算；未上市公司则常参照最近一轮融资价格，但该价格能否在离职时"变现"仍取决于协议及公司是否配合。';
      }
    } else {
      optionNote = '未填写协议回购价格或公允价值，暂无法估算，仅能提示价值方向。';
    }
    optionValue = perShareValue * optionShares;
  }

  const listedNote = (companyListed === 'listed')
    ? '公司已上市，通常有公开市场价格作为估值参考，但离职后的行权窗口期（常见为60–90天内需完成行权，逾期作废）、限售期规定仍需对照协议核实。'
    : '公司尚未上市，没有公开交易价格，估值分歧是未上市公司股权激励纠纷中最主要的争议点之一——法院可能参考最近一轮融资估值、第三方评估报告，也可能直接按协议约定的回购价格处理，甚至认为期权收益不属于劳动报酬、不属于劳动仲裁受理范围而告知另案起诉。';

  const disputeNote = '关于期权/股权激励纠纷的性质，司法实践长期存在<strong>两种对立观点</strong>：一种认为其源于劳动关系、构成广义的劳动报酬或福利，应作为劳动争议处理，甚至可计入经济补偿的月工资基数；另一种认为股权激励协议属于平等主体间的商事合同关系，与劳动报酬性质不同，应作为普通民事合同纠纷另案起诉，不适用劳动仲裁前置程序。<strong>两种观点在不同地区、不同法院甚至同一地区不同时期的判决中都能找到支持案例</strong>，具体结果高度依赖你的股权激励协议措辞、授予背景及当地裁判倾向。';

  $('optionGuidance').innerHTML =
    '<p style="font-size:12.5px; color:var(--ink-soft); margin:0 0 8px;">' + listedNote + '</p>' +
    '<p style="font-size:12.5px; color:var(--ink-soft); margin:0 0 8px;">' + optionNote + '</p>' +
    '<p style="font-size:12.5px; color:var(--ink-soft); margin:0;">' + disputeNote + '</p>';

  let total = comp + notice + leaveComp + otComp + contractComp + owedTotal;

  $('yearsOut').textContent = yearsLabel;
  $('baseOut').textContent = wageBase > 0 ? fmt(wageBase) + (capped? '（已封顶）':'') : '—';
  $('compLabel').textContent = compLabelText;
  $('compNote').textContent = compNoteText;
  $('compOut').textContent = fmt(comp);
  $('noticeOut').textContent = fmt(notice);
  $('leaveOut').textContent = fmt(leaveComp);
  $('owedOut').textContent = fmt(owedTotal);
  $('optionOut').textContent = fmt(optionValue);
  $('contractOut').textContent = fmt(contractComp);
  $('otOut').textContent = fmt(otComp);
  $('totalFigure').innerHTML = fmt(total) + ' <span class="unit">元（估算）</span>';

  $('zeroCompNote').style.display = zeroComp ? 'block' : 'none';
}

document.querySelectorAll('input, select').forEach(el=>{
  el.addEventListener('input', calc);
  el.addEventListener('change', calc);
});
calc();
</script>
</body>
</html>
